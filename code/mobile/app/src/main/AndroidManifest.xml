<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.NFC" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <uses-feature android:name="android.hardware.nfc" android:required="true" />
    <uses-feature android:name="android.hardware.camera" android:required="true" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SMTTS"
        android:usesCleartextTraffic="true">

        <!-- Login screen (launcher) -->
        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Activation screen (first-time registration) -->
        <activity
            android:name=".ui.login.ActivationActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Enrollment screen (NFC + Face biometric registration) -->
        <activity
            android:name=".ui.enrollment.EnrollmentActivity"
            android:exported="false" />

        <!-- Check-in screen (NFC + Face attendance) -->
        <activity
            android:name=".ui.checkin.CheckinActivity"
            android:exported="false" />

        <!-- Main app screen (after login) -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- SA-05: Profile screen -->
        <activity
            android:name=".ui.profile.ProfileActivity"
            android:exported="false" />

        <!-- SA-06: Geofence screen -->
        <activity
            android:name=".ui.geofence.GeofenceActivity"
            android:exported="false" />

        <!-- SA-07: History screen -->
        <activity
            android:name=".ui.history.HistoryActivity"
            android:exported="false" />

        <!-- SA-08: Notification screen -->
        <activity
            android:name=".ui.notification.NotificationActivity"
            android:exported="false" />

        <!-- SA-09: Request screens -->
        <activity
            android:name=".ui.request.RequestListActivity"
            android:exported="false" />

        <activity
            android:name=".ui.request.CreateRequestActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- SA-10: Device screen -->
        <activity
            android:name=".ui.device.DeviceActivity"
            android:exported="false" />

        <!-- SA-11: Document screen -->
        <activity
            android:name=".ui.document.DocumentActivity"
            android:exported="false" />

        <!-- SA-12: Contact screen -->
        <activity
            android:name=".ui.contact.ContactActivity"
            android:exported="false" />

        <!-- SA-14: Settings screen -->
        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false" />

    </application>

</manifest>
