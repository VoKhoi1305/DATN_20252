<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.SMTTS" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary: SMTTS Red -->
        <item name="colorPrimary">@color/smtts_red_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/smtts_red_100</item>
        <item name="colorOnPrimaryContainer">@color/smtts_red_900</item>

        <!-- Error: Same red -->
        <item name="colorError">@color/smtts_red_700</item>
        <item name="colorOnError">@color/white</item>

        <!-- Surface -->
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/smtts_zinc_900</item>
        <item name="colorOnSurfaceVariant">@color/smtts_zinc_500</item>
        <item name="colorOutline">@color/smtts_zinc_300</item>
        <item name="colorOutlineVariant">@color/smtts_zinc_200</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/smtts_red_700</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
    </style>

    <style name="Theme.SMTTS" parent="Base.Theme.SMTTS" />

    <!-- Login-specific button style -->
    <style name="Widget.SMTTS.Button.Login" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="backgroundTint">@color/smtts_red_700</item>
    </style>

    <!-- Outlined TextInputLayout style override -->
    <style name="Widget.SMTTS.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="hintTextColor">@color/smtts_red_700</item>
    </style>

</resources>
