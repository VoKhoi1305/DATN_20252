<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white"
    tools:context=".ui.login.ActivationActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Red accent bar -->
        <View
            android:id="@+id/accentBar"
            android:layout_width="0dp"
            android:layout_height="@dimen/accent_bar_height"
            android:background="@color/smtts_red_700"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Form content container -->
        <LinearLayout
            android:id="@+id/formContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/form_padding_horizontal"
            android:paddingTop="@dimen/spacing_lg"
            android:paddingBottom="@dimen/spacing_lg"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toTopOf="@id/footerText"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/accentBar"
            app:layout_constraintVertical_bias="0.32"
            app:layout_constraintWidth_max="@dimen/form_max_width">

            <!-- Logo row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/logo_size"
                    android:layout_height="@dimen/logo_size"
                    android:contentDescription="@string/brand_name"
                    android:src="@drawable/ic_shield" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/brand_name"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="@dimen/text_lg"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/activate_title"
                android:textColor="@color/smtts_zinc_900"
                android:textSize="@dimen/text_lg"
                android:textStyle="bold" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:text="@string/activate_subtitle"
                android:textColor="@color/smtts_zinc_500"
                android:textSize="@dimen/text_sm" />

            <!-- Subject code input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilSubjectCode"
                style="@style/Widget.SMTTS.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/activate_subject_code_label"
                app:errorEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSubjectCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionNext"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textAllCaps="true"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="@dimen/text_base"
                    tools:hint="@string/activate_subject_code_hint" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- CCCD input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCccd"
                style="@style/Widget.SMTTS.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:hint="@string/activate_cccd_label"
                app:errorEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCccd"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionNext"
                    android:inputType="number"
                    android:maxLength="12"
                    android:maxLines="1"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="@dimen/text_base"
                    tools:hint="@string/activate_cccd_hint" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/Widget.SMTTS.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:hint="@string/activate_password_label"
                app:endIconMode="password_toggle"
                app:errorEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionNext"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="@dimen/text_base"
                    tools:hint="@string/activate_password_hint" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Confirm password input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilConfirmPassword"
                style="@style/Widget.SMTTS.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:hint="@string/activate_confirm_password_label"
                app:endIconMode="password_toggle"
                app:errorEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionDone"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="@dimen/text_base"
                    tools:hint="@string/activate_confirm_password_hint" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Activate button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnActivate"
                style="@style/Widget.SMTTS.Button.Login"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="@string/activate_submit" />

            <!-- Link to login -->
            <TextView
                android:id="@+id/tvLoginLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/spacing_md"
                android:paddingVertical="@dimen/spacing_sm"
                android:text="@string/activate_login_link"
                android:textColor="@color/smtts_red_700"
                android:textSize="@dimen/text_sm" />

        </LinearLayout>

        <!-- Footer -->
        <TextView
            android:id="@+id/footerText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="@dimen/spacing_md"
            android:text="@string/footer_copyright"
            android:textColor="@color/smtts_zinc_500"
            android:textSize="@dimen/text_xs"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
