<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Icon -->
        <TextView
            android:id="@+id/tvRequestIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:textSize="18sp"
            tools:text="✈️" />

        <!-- Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvRequestType"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="@dimen/text_sm"
                    android:textStyle="bold"
                    tools:text="Xin đi xa" />

                <TextView
                    android:id="@+id/tvRequestStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_xs"
                    android:textStyle="bold"
                    tools:text="Đang chờ" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvRequestDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/smtts_zinc_500"
                android:textSize="@dimen/text_xs"
                tools:text="Gửi ngày: 20/03/2025" />

            <TextView
                android:id="@+id/tvRequestReason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/smtts_zinc_700"
                android:textSize="@dimen/text_sm"
                android:visibility="gone"
                tools:text="Về thăm gia đình" />

            <TextView
                android:id="@+id/tvReviewNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/smtts_red_600"
                android:textSize="@dimen/text_xs"
                android:visibility="gone"
                tools:text="Lý do từ chối: Chưa đủ giấy tờ" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
