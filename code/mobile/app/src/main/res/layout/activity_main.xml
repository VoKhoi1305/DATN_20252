<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/smtts_zinc_50"
    tools:context=".MainActivity">

    <!-- ═══ Top Header Bar ═══ -->
    <LinearLayout
        android:id="@+id/headerBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/smtts_red_700"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingVertical="14dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="@string/brand_name"
            android:src="@drawable/ic_shield"
            app:tint="@color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_weight="1"
            android:text="@string/brand_name"
            android:textColor="@color/white"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minWidth="0dp"
            android:paddingHorizontal="12dp"
            android:text="@string/dashboard_logout"
            android:textColor="@color/white"
            android:textSize="@dimen/text_sm"
            app:icon="@drawable/ic_logout"
            app:iconSize="16dp"
            app:iconTint="@color/white"
            app:rippleColor="#33FFFFFF" />

    </LinearLayout>

    <!-- ═══ Scrollable Content ═══ -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- ═══ User Info Card ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUserInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md">

                    <!-- Avatar circle -->
                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp">

                        <View
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_icon_circle_red" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/dashboard_profile"
                            android:src="@drawable/ic_person"
                            app:tint="@color/white" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_welcome"
                            android:textColor="@color/smtts_zinc_500"
                            android:textSize="@dimen/text_sm" />

                        <TextView
                            android:id="@+id/tvUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/smtts_zinc_900"
                            android:textSize="@dimen/text_lg"
                            android:textStyle="bold"
                            tools:text="Nguyễn Văn A" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/dashboard_role_label"
                                android:textColor="@color/smtts_zinc_400"
                                android:textSize="@dimen/text_xs" />

                            <TextView
                                android:id="@+id/tvUserRole"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:textColor="@color/smtts_red_700"
                                android:textSize="@dimen/text_xs"
                                android:textStyle="bold"
                                tools:text="SUBJECT" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_sm"
                                android:text="@string/dashboard_area_label"
                                android:textColor="@color/smtts_zinc_400"
                                android:textSize="@dimen/text_xs" />

                            <TextView
                                android:id="@+id/tvUserArea"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:textColor="@color/smtts_zinc_700"
                                android:textSize="@dimen/text_xs"
                                android:textStyle="bold"
                                tools:text="Phường 1" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ Quick Actions Title ═══ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="@string/dashboard_quick_actions"
                android:textColor="@color/smtts_zinc_700"
                android:textSize="@dimen/text_base"
                android:textStyle="bold" />

            <!-- ═══ Quick Actions Grid (2x2) ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:orientation="horizontal">

                <!-- Check-in Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCheckin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:rippleColor="@color/smtts_red_100">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginBottom="@dimen/spacing_sm">

                            <View
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_icon_circle_outline" />

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/dashboard_checkin"
                                android:src="@drawable/ic_checkin"
                                app:tint="@color/smtts_red_700" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/dashboard_checkin"
                            android:textColor="@color/smtts_zinc_900"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/dashboard_checkin_desc"
                            android:textColor="@color/smtts_zinc_400"
                            android:textSize="@dimen/text_xs" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Enrollment Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardEnrollment"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:rippleColor="@color/smtts_red_100">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginBottom="@dimen/spacing_sm">

                            <View
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_icon_circle_outline" />

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/dashboard_enrollment"
                                android:src="@drawable/ic_fingerprint"
                                app:tint="@color/smtts_red_700" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/dashboard_enrollment"
                            android:textColor="@color/smtts_zinc_900"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/dashboard_enrollment_desc"
                            android:textColor="@color/smtts_zinc_400"
                            android:textSize="@dimen/text_xs" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- History Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHistory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:rippleColor="@color/smtts_red_100">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginBottom="@dimen/spacing_sm">

                            <View
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_icon_circle_outline" />

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/dashboard_history"
                                android:src="@drawable/ic_history"
                                app:tint="@color/smtts_red_700" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/dashboard_history"
                            android:textColor="@color/smtts_zinc_900"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/dashboard_history_desc"
                            android:textColor="@color/smtts_zinc_400"
                            android:textSize="@dimen/text_xs" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Profile Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardProfile"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:rippleColor="@color/smtts_red_100">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginBottom="@dimen/spacing_sm">

                            <View
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_icon_circle_outline" />

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/dashboard_profile"
                                android:src="@drawable/ic_person"
                                app:tint="@color/smtts_red_700" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/dashboard_profile"
                            android:textColor="@color/smtts_zinc_900"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/dashboard_profile_desc"
                            android:textColor="@color/smtts_zinc_400"
                            android:textSize="@dimen/text_xs" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ═══ Quick Actions Row 3 (Notification + Request) ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:orientation="horizontal">

                <!-- Notification Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardNotification"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:rippleColor="@color/smtts_red_100">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginBottom="@dimen/spacing_sm">

                            <View
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_icon_circle_outline" />

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/dashboard_notification"
                                android:src="@drawable/ic_notification"
                                app:tint="@color/smtts_red_700" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/dashboard_notification"
                            android:textColor="@color/smtts_zinc_900"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/dashboard_notification_desc"
                            android:textColor="@color/smtts_zinc_400"
                            android:textSize="@dimen/text_xs" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Request Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRequest"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:rippleColor="@color/smtts_red_100">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginBottom="@dimen/spacing_sm">

                            <View
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_icon_circle_outline" />

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/dashboard_request"
                                android:src="@drawable/ic_request"
                                app:tint="@color/smtts_red_700" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/dashboard_request"
                            android:textColor="@color/smtts_zinc_900"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/dashboard_request_desc"
                            android:textColor="@color/smtts_zinc_400"
                            android:textSize="@dimen/text_xs" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ═══ Quick Actions Row 4 (Geofence + Device) ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:orientation="horizontal">

                <!-- Geofence Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardGeofence"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:rippleColor="@color/smtts_red_100">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginBottom="@dimen/spacing_sm">

                            <View
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_icon_circle_outline" />

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/dashboard_geofence"
                                android:src="@drawable/ic_location"
                                app:tint="@color/smtts_red_700" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/dashboard_geofence"
                            android:textColor="@color/smtts_zinc_900"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/dashboard_geofence_desc"
                            android:textColor="@color/smtts_zinc_400"
                            android:textSize="@dimen/text_xs" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Device Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDevice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:rippleColor="@color/smtts_red_100">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginBottom="@dimen/spacing_sm">

                            <View
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_icon_circle_outline" />

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/dashboard_device"
                                android:src="@drawable/ic_device"
                                app:tint="@color/smtts_red_700" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/dashboard_device"
                            android:textColor="@color/smtts_zinc_900"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/dashboard_device_desc"
                            android:textColor="@color/smtts_zinc_400"
                            android:textSize="@dimen/text_xs" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ═══ Quick Actions Row 5 (Document + Contact) ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:orientation="horizontal">

                <!-- Document Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDocument"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:rippleColor="@color/smtts_red_100">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginBottom="@dimen/spacing_sm">

                            <View
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_icon_circle_outline" />

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/dashboard_document"
                                android:src="@drawable/ic_document"
                                app:tint="@color/smtts_red_700" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/dashboard_document"
                            android:textColor="@color/smtts_zinc_900"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/dashboard_document_desc"
                            android:textColor="@color/smtts_zinc_400"
                            android:textSize="@dimen/text_xs" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Contact Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardContact"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:rippleColor="@color/smtts_red_100">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginBottom="@dimen/spacing_sm">

                            <View
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_icon_circle_outline" />

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/dashboard_contact"
                                android:src="@drawable/ic_phone"
                                app:tint="@color/smtts_red_700" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/dashboard_contact"
                            android:textColor="@color/smtts_zinc_900"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/dashboard_contact_desc"
                            android:textColor="@color/smtts_zinc_400"
                            android:textSize="@dimen/text_xs" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ═══ Quick Actions Row 6 (Settings) ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:orientation="horizontal">

                <!-- Settings Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSettings"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:rippleColor="@color/smtts_red_100">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginBottom="@dimen/spacing_sm">

                            <View
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_icon_circle_outline" />

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/dashboard_settings"
                                android:src="@drawable/ic_settings"
                                app:tint="@color/smtts_red_700" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/dashboard_settings"
                            android:textColor="@color/smtts_zinc_900"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="@string/dashboard_settings_desc"
                            android:textColor="@color/smtts_zinc_400"
                            android:textSize="@dimen/text_xs" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Empty spacer -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <!-- ═══ Footer ═══ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="@string/footer_copyright"
                android:textColor="@color/smtts_zinc_400"
                android:textSize="@dimen/text_xs" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
