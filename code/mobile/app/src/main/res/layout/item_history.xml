<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Date -->
        <TextView
            android:id="@+id/tvEventDate"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/smtts_zinc_700"
            android:textSize="@dimen/text_sm"
            android:textStyle="bold"
            tools:text="21/03" />

        <!-- Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvEventStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="@dimen/text_sm"
                    android:textStyle="bold"
                    tools:text="Đã điểm danh" />

                <TextView
                    android:id="@+id/tvEventTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/smtts_zinc_500"
                    android:textSize="@dimen/text_xs"
                    tools:text="07:15" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvEventDetail1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="@dimen/text_xs"
                android:visibility="gone"
                tools:text="Trong khu vực" />

            <TextView
                android:id="@+id/tvEventDetail2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="@dimen/text_xs"
                android:visibility="gone"
                tools:text="Khuôn mặt khớp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
