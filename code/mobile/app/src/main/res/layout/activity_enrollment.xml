<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/smtts_bg"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/enrollment_title"
            android:textAlignment="center"
            android:textColor="@color/smtts_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"
            android:text="@string/enrollment_subtitle"
            android:textAlignment="center"
            android:textColor="@color/smtts_text_secondary"
            android:textSize="14sp" />

        <!-- Step Indicators -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- Step 1: NFC -->
            <LinearLayout
                android:id="@+id/stepNfcContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/stepNfcIndicator"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/ic_shield"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/enrollment_step_nfc"
                    android:textColor="@color/smtts_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:layout_gravity="center_vertical"
                android:layout_marginBottom="18dp"
                android:background="@color/smtts_border" />

            <!-- Step 2: Face -->
            <LinearLayout
                android:id="@+id/stepFaceContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/stepFaceIndicator"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/ic_shield"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/enrollment_step_face"
                    android:textColor="@color/smtts_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═════════════════════════════════════ -->
        <!-- NFC Scan Section                      -->
        <!-- ═════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardNfc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/enrollment_nfc_title"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/enrollment_nfc_instruction"
                    android:textColor="@color/smtts_text_secondary"
                    android:textSize="14sp" />

                <!-- NFC status message -->
                <TextView
                    android:id="@+id/tvNfcStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/enrollment_nfc_waiting"
                    android:textAlignment="center"
                    android:textColor="@color/smtts_primary"
                    android:textSize="14sp"
                    android:textStyle="italic" />

                <!-- NFC success checkmark (hidden by default) -->
                <TextView
                    android:id="@+id/tvNfcSuccess"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAlignment="center"
                    android:textColor="#16a34a"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="Đăng ký NFC thành công" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═════════════════════════════════════ -->
        <!-- Face Capture Section                  -->
        <!-- ═════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/enrollment_face_title"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/enrollment_face_instruction"
                    android:textColor="@color/smtts_text_secondary"
                    android:textSize="14sp" />

                <!-- Camera preview -->
                <androidx.camera.view.PreviewView
                    android:id="@+id/cameraPreview"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_marginTop="12dp"
                    android:visibility="gone" />

                <!-- Capture button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCaptureFace"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/enrollment_face_capture_btn"
                    android:textColor="@color/white"
                    android:enabled="false"
                    app:backgroundTint="@color/smtts_primary" />

                <!-- Face success message -->
                <TextView
                    android:id="@+id/tvFaceSuccess"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAlignment="center"
                    android:textColor="#16a34a"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="Đăng ký khuôn mặt thành công" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Continue button (shown when enrollment is complete) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:text="@string/enrollment_continue"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:visibility="gone"
            app:backgroundTint="@color/smtts_primary"
            app:cornerRadius="8dp" />

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
