<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/smtts_zinc_50"
    tools:context=".ui.enrollment.EnrollmentActivity">

    <!-- ═══ Header Bar ═══ -->
    <LinearLayout
        android:id="@+id/headerBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/smtts_red_700"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingVertical="14dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="@string/enrollment_back"
            android:padding="2dp"
            android:src="@drawable/ic_logout"
            android:rotation="180"
            app:tint="@color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_weight="1"
            android:text="@string/enrollment_title"
            android:textColor="@color/white"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ═══ Step Indicator ═══ -->
    <LinearLayout
        android:id="@+id/stepIndicator"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingVertical="@dimen/spacing_md"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:background="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerBar">

        <!-- Step 1 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvStep1"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_step_active"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStep1Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/enrollment_step_nfc"
                android:textColor="@color/smtts_red_700"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Line 1→2 -->
        <View
            android:id="@+id/line1"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_marginHorizontal="@dimen/spacing_sm"
            android:layout_weight="1"
            android:layout_gravity="top"
            android:layout_marginTop="15dp"
            android:background="@drawable/bg_step_line_inactive" />

        <!-- Step 2 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvStep2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_step_inactive"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStep2Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/enrollment_step_face"
                android:textColor="@color/smtts_zinc_400"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Line 2→3 -->
        <View
            android:id="@+id/line2"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_marginHorizontal="@dimen/spacing_sm"
            android:layout_weight="1"
            android:layout_gravity="top"
            android:layout_marginTop="15dp"
            android:background="@drawable/bg_step_line_inactive" />

        <!-- Step 3 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvStep3"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_step_inactive"
                android:gravity="center"
                android:text="3"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStep3Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/enrollment_step_submit"
                android:textColor="@color/smtts_zinc_400"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ═══ Step Content (scrollable) ═══ -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/stepIndicator">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ═══════════════════════════════════════ -->
            <!-- STEP 1: NFC SCAN                       -->
            <!-- ═══════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/stepNfc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md"
                android:visibility="visible">

                <!-- NFC Config Section (shown if BAC not configured) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardNfcConfig"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_sm"
                            android:text="@string/enrollment_nfc_config_needed"
                            android:textColor="@color/smtts_zinc_700"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilNfcCccd"
                            style="@style/Widget.SMTTS.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_sm"
                            android:hint="@string/nfc_config_cccd_label">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etNfcCccd"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:maxLength="12" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilNfcDob"
                            style="@style/Widget.SMTTS.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_sm"
                            android:hint="@string/nfc_config_dob_label">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etNfcDob"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:digits="0123456789/"
                                android:maxLength="10" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilNfcExpiry"
                            style="@style/Widget.SMTTS.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_sm"
                            android:hint="@string/nfc_config_expiry_label">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etNfcExpiry"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:digits="0123456789/"
                                android:maxLength="10" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSaveNfcConfig"
                            style="@style/Widget.SMTTS.Button.Login"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/button_height"
                            android:text="@string/enrollment_nfc_save_config" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- NFC Scan Waiting Area -->
                <LinearLayout
                    android:id="@+id/nfcWaitingArea"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_xl"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/ivNfcPulse"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:padding="16dp"
                        android:background="@drawable/bg_icon_circle_red"
                        android:src="@drawable/ic_nfc"
                        android:contentDescription="NFC"
                        app:tint="@color/white" />

                    <TextView
                        android:id="@+id/tvNfcStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/enrollment_nfc_waiting"
                        android:textColor="@color/smtts_red_700"
                        android:textSize="@dimen/text_base"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:gravity="center"
                        android:text="@string/enrollment_nfc_instruction"
                        android:textColor="@color/smtts_zinc_500"
                        android:textSize="@dimen/text_sm" />

                    <ProgressBar
                        android:id="@+id/progressNfcRead"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:indeterminate="true"
                        android:indeterminateTint="@color/smtts_red_700"
                        android:visibility="gone" />

                    <!-- Nút sửa thông tin BAC nếu nhập sai -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEditNfcConfig"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/enrollment_nfc_edit_config"
                        android:textColor="@color/smtts_zinc_500"
                        android:textSize="@dimen/text_sm" />
                </LinearLayout>

                <!-- NFC Read Result Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardNfcResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:strokeColor="#BBF7D0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_sm"
                            android:text="@string/enrollment_nfc_read_ok"
                            android:textColor="#16A34A"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold" />

                        <include
                            android:id="@+id/nfcDataRows"
                            layout="@layout/include_nfc_data_rows" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- NFC Submit / Next buttons -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNfcSubmit"
                    style="@style/Widget.SMTTS.Button.Login"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:text="@string/enrollment_nfc_submit_btn"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNfcNext"
                    style="@style/Widget.SMTTS.Button.Login"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:text="@string/enrollment_next"
                    android:visibility="gone" />

                <!-- NFC progress -->
                <ProgressBar
                    android:id="@+id/progressNfcSubmit"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- ═══════════════════════════════════════ -->
            <!-- STEP 2: FACE CAPTURE                   -->
            <!-- ═══════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/stepFace"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:text="@string/enrollment_face_title"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="@dimen/text_lg"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:text="@string/enrollment_face_instruction"
                    android:textColor="@color/smtts_zinc_500"
                    android:textSize="@dimen/text_sm" />

                <!-- Camera preview -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <androidx.camera.view.PreviewView
                        android:id="@+id/cameraPreview"
                        android:layout_width="match_parent"
                        android:layout_height="360dp" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Face quality result (shown after capture) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFaceResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:visibility="gone"
                    app:cardBackgroundColor="#F0FDF4"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#BBF7D0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/enrollment_face_success"
                            android:textColor="#16A34A"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvFaceQuality"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/smtts_zinc_700"
                            android:textSize="@dimen/text_sm"
                            tools:text="Chất lượng: 89%" />

                        <TextView
                            android:id="@+id/tvFaceLiveness"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/smtts_zinc_700"
                            android:textSize="@dimen/text_sm"
                            tools:text="Liveness: 95%" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Capture / Retry buttons -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCaptureFace"
                    style="@style/Widget.SMTTS.Button.Login"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:text="@string/enrollment_face_capture_btn" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFaceNext"
                    style="@style/Widget.SMTTS.Button.Login"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="@string/enrollment_next"
                    android:visibility="gone" />

                <ProgressBar
                    android:id="@+id/progressFace"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- ═══════════════════════════════════════ -->
            <!-- STEP 3: REVIEW & SUBMIT                -->
            <!-- ═══════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/stepSubmit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_xs"
                    android:text="@string/enrollment_submit_title"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="@dimen/text_lg"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_lg"
                    android:text="@string/enrollment_submit_subtitle"
                    android:textColor="@color/smtts_zinc_500"
                    android:textSize="@dimen/text_sm" />

                <!-- NFC Summary -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    app:cardBackgroundColor="#F0FDF4"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#BBF7D0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_md">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp">
                            <View
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_step_done" />
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_nfc"
                                app:tint="@color/white"
                                android:contentDescription="NFC" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_md"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/enrollment_submit_nfc_label"
                                android:textColor="#16A34A"
                                android:textSize="@dimen/text_sm"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvSubmitNfcInfo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/smtts_zinc_700"
                                android:textSize="@dimen/text_xs"
                                tools:text="NGUYEN VAN A — 012345678901" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Face Summary -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_lg"
                    app:cardBackgroundColor="#F0FDF4"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#BBF7D0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_md">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp">
                            <View
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_step_done" />
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_person"
                                app:tint="@color/white"
                                android:contentDescription="Face" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_md"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/enrollment_submit_face_label"
                                android:textColor="#16A34A"
                                android:textSize="@dimen/text_sm"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvSubmitFaceInfo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/smtts_zinc_700"
                                android:textSize="@dimen/text_xs"
                                tools:text="Chất lượng: 89% — Liveness: 95%" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Submit button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmitEnrollment"
                    style="@style/Widget.SMTTS.Button.Login"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:text="@string/enrollment_submit_btn" />

                <!-- Success area (shown after submit) -->
                <LinearLayout
                    android:id="@+id/enrollmentSuccessArea"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/spacing_xl"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:padding="14dp"
                        android:background="@drawable/bg_step_done"
                        android:src="@drawable/ic_shield"
                        android:contentDescription="Success"
                        app:tint="@color/white" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:gravity="center"
                        android:text="@string/enrollment_submit_success_title"
                        android:textColor="#16A34A"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:gravity="center"
                        android:text="@string/enrollment_submit_success_msg"
                        android:textColor="@color/smtts_zinc_500"
                        android:textSize="@dimen/text_sm" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBackToHome"
                        style="@style/Widget.SMTTS.Button.Login"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/spacing_lg"
                        android:text="@string/enrollment_submit_back_home" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressSubmit"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:visibility="gone" />
            </LinearLayout>

        </FrameLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
