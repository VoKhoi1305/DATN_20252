<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="@dimen/spacing_md"
        android:background="@drawable/bg_drag_handle" />

    <!-- Header with icon and title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/spacing_md">

        <ImageView
            android:id="@+id/ivNfcIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:background="@drawable/bg_icon_circle_green"
            android:src="@drawable/ic_nfc"
            android:contentDescription="NFC"
            app:tint="@color/white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_md"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNfcResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nfc_result_title"
                android:textColor="@color/smtts_zinc_900"
                android:textSize="@dimen/text_lg"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvNfcResultStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nfc_result_reading"
                android:textColor="@color/smtts_zinc_500"
                android:textSize="@dimen/text_sm" />
        </LinearLayout>
    </LinearLayout>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/progressNfc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_md"
        style="?android:attr/progressBarStyleHorizontal"
        android:indeterminate="true"
        android:indeterminateTint="@color/smtts_red_700" />

    <!-- Info card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardNfcInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_md"
        android:visibility="gone"
        app:cardBackgroundColor="@color/smtts_zinc_50"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/smtts_zinc_200"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- Full Name -->
            <LinearLayout
                android:id="@+id/rowFullName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.4"
                    android:text="@string/nfc_result_fullname"
                    android:textColor="@color/smtts_zinc_500"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:id="@+id/tvFullName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.6"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="@dimen/text_sm"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:background="@color/smtts_zinc_200" />

            <!-- CCCD Number -->
            <LinearLayout
                android:id="@+id/rowCccd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.4"
                    android:text="@string/nfc_result_cccd"
                    android:textColor="@color/smtts_zinc_500"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:id="@+id/tvCccdNumber"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.6"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="@dimen/text_sm"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:background="@color/smtts_zinc_200" />

            <!-- Date of Birth -->
            <LinearLayout
                android:id="@+id/rowDob"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.4"
                    android:text="@string/nfc_result_dob"
                    android:textColor="@color/smtts_zinc_500"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:id="@+id/tvDob"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.6"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="@dimen/text_sm" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:background="@color/smtts_zinc_200" />

            <!-- Gender -->
            <LinearLayout
                android:id="@+id/rowGender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.4"
                    android:text="@string/nfc_result_gender"
                    android:textColor="@color/smtts_zinc_500"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:id="@+id/tvGender"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.6"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="@dimen/text_sm" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:background="@color/smtts_zinc_200" />

            <!-- Nationality -->
            <LinearLayout
                android:id="@+id/rowNationality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.4"
                    android:text="@string/nfc_result_nationality"
                    android:textColor="@color/smtts_zinc_500"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:id="@+id/tvNationality"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.6"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="@dimen/text_sm" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:background="@color/smtts_zinc_200" />

            <!-- Expiry Date -->
            <LinearLayout
                android:id="@+id/rowExpiry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.4"
                    android:text="@string/nfc_result_expiry"
                    android:textColor="@color/smtts_zinc_500"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:id="@+id/tvExpiry"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.6"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="@dimen/text_sm" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:background="@color/smtts_zinc_200" />

            <!-- Chip Serial -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.4"
                    android:text="@string/nfc_result_chip_serial"
                    android:textColor="@color/smtts_zinc_500"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:id="@+id/tvChipSerial"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.6"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="@dimen/text_sm"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:background="@color/smtts_zinc_200" />

            <!-- Passive Auth -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.4"
                    android:text="@string/nfc_result_passive_auth"
                    android:textColor="@color/smtts_zinc_500"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:id="@+id/tvPassiveAuth"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.6"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="@dimen/text_sm" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Error message -->
    <TextView
        android:id="@+id/tvNfcError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_md"
        android:background="@color/smtts_red_100"
        android:padding="@dimen/spacing_md"
        android:textColor="@color/smtts_red_700"
        android:textSize="@dimen/text_sm"
        android:visibility="gone" />

    <!-- Close button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCloseNfcResult"
        style="@style/Widget.SMTTS.Button.Login"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:text="@string/nfc_result_close" />

</LinearLayout>
