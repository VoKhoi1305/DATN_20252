<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white"
    tools:context=".ui.login.LoginActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Red accent bar (3dp) matching web design -->
        <View
            android:id="@+id/accentBar"
            android:layout_width="0dp"
            android:layout_height="@dimen/accent_bar_height"
            android:background="@color/smtts_red_700"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Form content container (centered, max-w-380dp) -->
        <LinearLayout
            android:id="@+id/formContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:maxWidth="@dimen/form_max_width"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/form_padding_horizontal"
            android:paddingTop="@dimen/form_padding_vertical"
            android:paddingBottom="@dimen/spacing_lg"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toTopOf="@id/footerText"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/accentBar"
            app:layout_constraintVertical_bias="0.38"
            app:layout_constraintWidth_max="@dimen/form_max_width">

            <!-- Logo row: Shield icon + SMTTS text (inline, matching mobile layout SCR-001) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:layout_marginBottom="@dimen/spacing_xl"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/logo_size"
                    android:layout_height="@dimen/logo_size"
                    android:contentDescription="@string/brand_name"
                    android:src="@drawable/ic_shield" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/brand_name"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="@dimen/text_lg"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Title: "Đăng nhập hệ thống" -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/login_title"
                android:textColor="@color/smtts_zinc_900"
                android:textSize="@dimen/text_lg"
                android:textStyle="bold" />

            <!-- Subtitle: "Nhập tài khoản để tiếp tục" -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:text="@string/login_subtitle"
                android:textColor="@color/smtts_zinc_500"
                android:textSize="@dimen/text_sm" />

            <!-- Username input (TextInputLayout - OutlinedBox) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilUsername"
                style="@style/Widget.SMTTS.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/login_username_label"
                app:errorEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="username"
                    android:imeOptions="actionNext"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="@dimen/text_base"
                    tools:hint="@string/login_username_hint" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password input (TextInputLayout with password toggle) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/Widget.SMTTS.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:hint="@string/login_password_label"
                app:endIconMode="password_toggle"
                app:errorEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="password"
                    android:imeOptions="actionDone"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:textColor="@color/smtts_zinc_900"
                    android:textSize="@dimen/text_base"
                    tools:hint="@string/login_password_hint" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Login button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                style="@style/Widget.SMTTS.Button.Login"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="@string/login_submit" />

            <!-- Link to activation screen -->
            <TextView
                android:id="@+id/tvActivateLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/spacing_md"
                android:paddingVertical="@dimen/spacing_sm"
                android:text="@string/login_activate_link"
                android:textColor="@color/smtts_red_700"
                android:textSize="@dimen/text_sm" />

        </LinearLayout>

        <!-- Footer: "© 2026 SMTTS" -->
        <TextView
            android:id="@+id/footerText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="@dimen/spacing_md"
            android:text="@string/footer_copyright"
            android:textColor="@color/smtts_zinc_500"
            android:textSize="@dimen/text_xs"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
