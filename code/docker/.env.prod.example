# ============================================================
# SMTTS — Production environment example
# Copy to .env.prod and fill REAL secrets before deploying.
#   cp .env.prod.example .env.prod
# ============================================================

# Image tag — set by CI to the git SHA; "latest" works for manual deploys
IMAGE_TAG=latest

# Container registry prefix — must match where CI pushes images.
# Format: ghcr.io/<github-username-or-org-lowercase>
REGISTRY_PREFIX=ghcr.io/your-github-username

# Public port that the web (nginx) container will expose on the host.
# If you put Caddy/Cloudflare in front for HTTPS, keep this 80.
WEB_PUBLIC_PORT=80

# ---------- Main database ----------
DB_MAIN_NAME=smtts_main
DB_MAIN_USER=smtts_user
# REQUIRED — generate with: openssl rand -base64 32
DB_MAIN_PASSWORD=CHANGE_ME_strong_random_password

# ---------- Biometric database (separate per SBR-18) ----------
DB_BIO_NAME=smtts_biometric
DB_BIO_USER=smtts_bio_user
DB_BIO_PASSWORD=CHANGE_ME_another_strong_random

# ---------- JWT ----------
# REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_hex_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_TEMP_EXPIRY=5m
OTP_ISSUER=SMTTS

# ---------- Throttle ----------
THROTTLE_TTL=60000
THROTTLE_LIMIT=20

# ---------- Face recognition tuning ----------
FACE_DET_MODEL=buffalo_l
FACE_DEFAULT_MATCH_THRESHOLD=0.45
FACE_LIVENESS_THRESHOLD=0.5
FACE_ENABLE_LIVENESS=true
